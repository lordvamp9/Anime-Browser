<Window x:Class="vamp9.AnimeSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anime Setup" Height="450" Width="650"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Glossy Setup Button Template -->
        <ControlTemplate x:Key="GlossySetupButtonTemplate" TargetType="Button">
            <Border x:Name="border" CornerRadius="8" BorderThickness="1" BorderBrush="#88FFFFFF" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#66FFFFFF" Offset="0"/>
                        <GradientStop Color="#22FFFFFF" Offset="0.45"/>
                        <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect x:Name="shadow" BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.95" Duration="0:0:0.05" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.95" Duration="0:0:0.05" />
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="ShadowDepth" To="1" Duration="0:0:0.05"/>
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="5" Duration="0:0:0.05"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1" />
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="ShadowDepth" To="2" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="10" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="SetupButtonStyle" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource GlossySetupButtonTemplate}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="15" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#AA1A5B8C" Offset="0.0"/>
                <GradientStop Color="#DD3A8CBB" Offset="0.5"/>
                <GradientStop Color="#AA7AC5E9" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <!-- Glass Background Effect -->
            <Border Opacity="0.1" Background="{DynamicResource {x:Static SystemColors.DesktopBrushKey}}">
                <Border.Effect>
                    <BlurEffect Radius="150"/>
                </Border.Effect>
            </Border>
            <Border BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                </Border.Effect>
                
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="vamp9 Anime Suite Setup" Foreground="White" FontSize="28" FontWeight="Bold" FontFamily="Segoe UI">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <Path Data="M 10,10 L 20,10 L 15,20 Z" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <!-- Main Install Panel -->
                        <StackPanel x:Name="InstallPanel" Visibility="Visible">
                            <TextBlock x:Name="StatusText" Text="Inicializando..." Foreground="#FFFFFF" FontSize="18" FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,0,0,15" TextAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            
                            <!-- Glossy Progress Bar Container -->
                            <Border CornerRadius="5" Background="#44000000" Height="8" BorderThickness="1" BorderBrush="#33FFFFFF" Margin="0,0,0,20">
                                <ProgressBar x:Name="Progress" Height="6" BorderThickness="0" Background="Transparent" Maximum="100" Value="0">
                                    <ProgressBar.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00A2FF" Offset="0"/>
                                            <GradientStop Color="#00FFC4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </ProgressBar.Foreground>
                                </ProgressBar>
                            </Border>

                            <Border CornerRadius="8" Background="#22000000" BorderBrush="#22FFFFFF" BorderThickness="1">
                                <ScrollViewer x:Name="LogScroll" Height="180" Margin="5" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="LogText" Foreground="#E0E0E0" FontFamily="Consolas" FontSize="13" Margin="5" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <!-- Password Input Panel -->
                        <StackPanel x:Name="PasswordPanel" Visibility="Collapsed" VerticalAlignment="Center" Background="#22000000" Margin="20">
                            <TextBlock Text="Se requiere contraseña de sudo en WSL para instalar dependencias:" Foreground="White" FontSize="15" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#66FFFFFF" BorderThickness="1" Background="#33FFFFFF" Width="260" Height="35">
                                <PasswordBox x:Name="PasswordInput" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Padding="5"/>
                            </Border>
                            <TextBlock Text="La contraseña no se guardará y solo se usará para la instalación de apt." Foreground="#AAFFFFFF" FontSize="12" Margin="0,10,0,20" HorizontalAlignment="Center"/>
                            <Button Content="Confirmar" Style="{StaticResource SetupButtonStyle}" Width="120" Height="35" Click="ConfirmPassword_Click" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <Button x:Name="CloseButton" Style="{StaticResource SetupButtonStyle}" Grid.Row="2" Content="Cerrar Setup" Visibility="Collapsed" Click="CloseButton_Click" HorizontalAlignment="Right" Width="120" Height="35" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
