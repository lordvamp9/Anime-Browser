<Window x:Class="vamp9.AnimeDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anime Dashboard" Height="720" Width="1080"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <!-- Frutiger Aero Colors -->
        <Color x:Key="AeroBlue">#BBE2F1</Color>
        <Color x:Key="AeroDarkBlue">#3B8BBA</Color>
        <Color x:Key="AeroGreen">#A4E5C0</Color>
        <Color x:Key="GlassWhite">#44FFFFFF</Color>

        <!-- Glossy Button Template -->
        <ControlTemplate x:Key="GlossyButtonTemplate" TargetType="Button">
            <Border x:Name="border" CornerRadius="15" BorderThickness="1" BorderBrush="#88FFFFFF" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0.0"/>
                        <GradientStop Color="#11FFFFFF" Offset="0.45"/>
                        <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#22FFFFFF" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect x:Name="shadow" BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.95" Duration="0:0:0.05" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.95" Duration="0:0:0.05" />
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="ShadowDepth" To="1" Duration="0:0:0.05"/>
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="5" Duration="0:0:0.05"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1" />
                                <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1" />
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="ShadowDepth" To="2" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="10" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="AeroButtonStyle" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource GlossyButtonTemplate}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animations for Page Transitions -->
        <Storyboard x:Key="PageEnter">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,30,0,0" To="0,0,0,0" Duration="0:0:0.4">
                <ThicknessAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

    </Window.Resources>

    <!-- Main Window Frame -->
    <Border CornerRadius="15" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#AA1A5B8C" Offset="0.0"/>
                <GradientStop Color="#DD3A8CBB" Offset="0.5"/>
                <GradientStop Color="#AA7AC5E9" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        
        <Grid>
            <!-- Watery Aero Effect Background overlay -->
            <Border Opacity="0.15" Background="{DynamicResource {x:Static SystemColors.DesktopBrushKey}}">
                <Border.Effect>
                    <BlurEffect Radius="150"/>
                </Border.Effect>
            </Border>
            
            <Border BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar (Glass Panel) -->
                <Border Grid.Column="0" Background="#33FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="0,0,1,0" />
                <Grid Grid.Column="0" Margin="10,40,10,10">
                    <StackPanel>
                        <TextBlock Text="Anime Dashboard" Foreground="White" FontSize="22" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,15,0,40"/>

                        <Button Content=" Explorar" Style="{StaticResource AeroButtonStyle}" Height="40" Margin="0,5" Click="Nav_Browser_Click">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" Fill="White" Width="16" Height="16" Stretch="Fill" Margin="0,0,10,0"/>
                                        <TextBlock Text="Explorar" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Content=" Ver Más Tarde" Style="{StaticResource AeroButtonStyle}" Height="40" Margin="0,5" Click="Nav_WatchLater_Click">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z" Fill="White" Width="16" Height="16" Stretch="Fill" Margin="0,0,10,0"/>
                                        <TextBlock Text="Ver Más Tarde" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Content=" Lista Activa" Style="{StaticResource AeroButtonStyle}" Height="40" Margin="0,5" Click="Nav_Active_Click">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                     <StackPanel Orientation="Horizontal">
                                         <Path Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" Fill="White" Width="16" Height="16" Stretch="Fill" Margin="0,0,10,0"/>
                                         <TextBlock Text="Lista" VerticalAlignment="Center"/>
                                     </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Content=" Historial" Style="{StaticResource AeroButtonStyle}" Height="40" Margin="0,5" Click="Nav_History_Click">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" Fill="White" Width="16" Height="16" Stretch="Fill" Margin="0,0,10,0"/>
                                        <TextBlock Text="Historial" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Content=" Ajustes" Style="{StaticResource AeroButtonStyle}" Height="40" Margin="0,5" Click="Nav_Settings_Click">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" Fill="White" Width="16" Height="16" Stretch="Fill" Margin="0,0,10,0"/>
                                        <TextBlock Text="Ajustes" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                    
                    <Button Content="X" Style="{StaticResource AeroButtonStyle}" Height="30" Width="30" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="CloseApp_Click" ToolTip="Cerrar vamp9"/>
                </Grid>

                <!-- Content Area -->
                <Grid Grid.Column="1" Margin="20">
                    
                    <!-- View 1: Browser -->
                    <Grid x:Name="ViewBrowser" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Border Background="#33FFFFFF" CornerRadius="20" BorderBrush="#88FFFFFF" BorderThickness="1" Height="40">
                                <Grid>
                                    <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="16" Padding="15,0,0,0" VerticalContentAlignment="Center" KeyDown="SearchBox_KeyDown"/>
                                    <TextBlock Text="Buscar anime y presiona Enter..." Foreground="#AAFFFFFF" FontSize="16" VerticalAlignment="Center" Margin="15,0,0,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button HorizontalAlignment="Right" Width="40" Style="{StaticResource AeroButtonStyle}" Background="Transparent" BorderThickness="0" Click="SearchButton_Click">
                                        <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" Fill="White" Width="16" Height="16" Stretch="Fill"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>d>
                        
                        <DataGrid x:Name="SearchResultsGrid" Grid.Row="1" Background="#11FFFFFF" Foreground="White" RowBackground="#22FFFFFF" AlternatingRowBackground="#11FFFFFF" BorderThickness="0" AutoGenerateColumns="False" HeadersVisibility="Column" GridLinesVisibility="None" IsReadOnly="True" SelectionMode="Single" CanUserReorderColumns="False" CanUserResizeColumns="False">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nombre del Anime" Binding="{Binding Name}" Width="*"/>
                                <DataGridTemplateColumn Header="Acción" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource AeroButtonStyle}" Width="40" Height="30" Margin="5" Click="PlayAnime_Click" Tag="{Binding Name}">
                                                <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="White" Width="12" Height="12" Stretch="Fill"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="+" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource AeroButtonStyle}" Width="30" Height="30" Margin="2" Click="AddWatchLater_Click" Tag="{Binding Name}">
                                                <TextBlock Text="+" FontSize="18" FontWeight="Bold"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="SearchLoadingText" Grid.Row="1" Text="Buscando en ani-es..." Foreground="#A4E5C0" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>

                    <!-- View 2: Watch Later -->
                    <Grid x:Name="ViewWatchLater" Visibility="Collapsed">
                        <TextBlock Text="Ver Más Tarde" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" VerticalAlignment="Top"/>
                        <ScrollViewer Margin="0,40,0,0">
                            <ItemsControl x:Name="WatchLaterList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="200" Height="100" Background="#22FFFFFF" CornerRadius="10" BorderBrush="#55FFFFFF" BorderThickness="1" Margin="10">
                                            <Grid Margin="10">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                                <Button Style="{StaticResource AeroButtonStyle}" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="PlayAnime_Click" Tag="{Binding Name}">
                                                    <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="White" Width="10" Height="10" Stretch="Fill"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- View 3: Active List -->
                    <Grid x:Name="ViewActive" Visibility="Collapsed">
                        <TextBlock Text="Animes pendientes" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" VerticalAlignment="Top"/>
                        <ListView x:Name="ActiveListView" Margin="0,40,0,0" Background="#11FFFFFF" Foreground="White" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5" Width="800">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EpisodeText}" Foreground="#A4E5C0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Style="{StaticResource AeroButtonStyle}" Content="Continuar" Click="PlayAnime_Click" Tag="{Binding Name}" Height="30"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- View 4: History -->
                    <Grid x:Name="ViewHistory" Visibility="Collapsed">
                        <TextBlock Text="Historial de Visualización" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" VerticalAlignment="Top"/>
                        <DataGrid x:Name="HistoryGrid" Margin="0,40,0,0" Background="#11FFFFFF" Foreground="White" RowBackground="#22FFFFFF" AlternatingRowBackground="#11FFFFFF" BorderThickness="0" AutoGenerateColumns="False" HeadersVisibility="Column" GridLinesVisibility="None" IsReadOnly="True" CanUserReorderColumns="False" CanUserResizeColumns="False">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Anime" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Último Cap" Binding="{Binding LastEpisode}" Width="100"/>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding LastWatched}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                    
                    <!-- View 5: Settings -->
                    <Grid x:Name="ViewSettings" Visibility="Collapsed">
                        <TextBlock Text="Ajustes de Reproducción" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" VerticalAlignment="Top"/>
                        
                        <!-- Main Settings controls -->
                        <StackPanel x:Name="SettingsMainPanel" Margin="0,50,0,0" Visibility="Visible">
                            <TextBlock Text="Configurar MPV con Perfil Premium de Video y Subtítulos" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Optimiza el escalado para anime (spline36), activa debanding avanzado, previene tirones en streaming e instala subtítulos estilo Crunchyroll." Foreground="#DDDDDD" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Button Content="custome" Style="{StaticResource AeroButtonStyle}" Width="150" Height="40" Click="BtnCustome_Click"/>
                                <Button Content="open mvp.conf" Style="{StaticResource AeroButtonStyle}" Width="150" Height="40" Margin="15,0,0,0" Click="BtnOpenMvpConf_Click"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="SettingsStatusText" Foreground="#A4E5C0" FontSize="14" Margin="0,15,0,0" Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Config File Editor -->
                        <Grid x:Name="ConfigEditorOverlay" Margin="0,50,0,0" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="ConfigTextBox" Grid.Row="0" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" Background="#DD102030" Foreground="White" BorderBrush="#55FFFFFF" BorderThickness="1" FontFamily="Consolas" FontSize="13" Padding="10" KeyDown="ConfigTextBox_KeyDown" Height="450"/>
                            <TextBlock Grid.Row="1" Text="Presiona ESC para guardar los cambios y volver." Foreground="#A4E5C0" FontSize="13" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </Grid>
                    </Grid>
                    
                    <!-- Modal Overlay (Episode Finished?) -->
                    <Border x:Name="ModalOverlay" Background="#99000000" Visibility="Collapsed" Grid.RowSpan="2">
                        <Border Background="#CC203A43" CornerRadius="15" Width="400" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#55FFFFFF" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.8"/>
                            </Border.Effect>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" Fill="#A4E5C0" Width="40" Height="40" Stretch="Fill" Margin="0,0,0,10"/>
                                    <TextBlock Text="¿Episodio finalizado?" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ModalAnimeName" Text="Anime Name" Foreground="#DDDDDD" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                                    <Button Content="Sí, sumar cap" Style="{StaticResource AeroButtonStyle}" Width="120" Height="35" Margin="0,0,10,0" Click="ModalYes_Click"/>
                                    <Button Content="No" Style="{StaticResource AeroButtonStyle}" Width="80" Height="35" Click="ModalNo_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                </Grid>
            </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
